# Backend Environment Configurations
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017/stuhub
JWT_SECRET=development-secret-change-me-should-be-at-least-16-characters-long
JWT_EXPIRES_IN=7d

# Cloudinary (Optional, for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Auth (Optional, for Google Sign-in)
GOOGLE_CLIENT_ID=

# AI Integration API Keys
GEMINI_API_KEY=
GROQ_API_KEY=
